}

/* ═══════════════════════════════════════════════════
   TRUST / STATS SECTION
   ═══════════════════════════════════════════════════ */
function TrustSection() {
  const stats = [
    { label: "Average markup at wholesale prices", value: "366.61%", color: "text-orange-600" },
    { label: "Active Deals as of today", value: "14,891+", color: "text-orange-600" },
    { label: "New Suppliers in the past 7 days", value: "300+", color: "text-orange-600" },
  ];

  const testimonials = [
    { name: "Rachel Harvey", location: "United Kingdom", text: "I am very pleased that I have subscribed to WholesaleDeals as the quality and service is excellent. The information you provide is very detailed and helpful...", rating: 5 },
    { name: "Thai Hoang Do", location: "Belgium", text: "Hello. Very pleased with the service, suppliers and dropshippers. I have just signed up to another full term for the next 6 months. Thank you.", rating: 5 },
    { name: "Alice Elliott", location: "United Kingdom", text: "Absolutely fantastic, it's a great service and has a really good layout. It's very convenient and it is updated very regularly.", rating: 5 },
  ];

  return (
    <div className="mt-12">
      <h2 className="text-2xl font-extrabold text-slate-900 text-center mb-8">Trusted by Businesses of All Sizes</h2>

      {/* Stats */}
      <div className="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
        {stats.map((s) => (
          <div key={s.label} className="text-center">
            <p className={`text-3xl font-extrabold ${s.color}`}>{s.value}</p>
            <p className="text-sm text-slate-500 mt-1">{s.label}</p>
          </div>
        ))}
      </div>

      {/* Testimonials */}
      <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <div key={t.name} className="bg-white rounded-xl border border-slate-200 p-5">
            <div className="flex items-center gap-0.5 mb-3">
              {Array.from({ length: t.rating }, (_, i) => (
                <Star key={i} size={14} className="fill-amber-400 text-amber-400" />
              ))}
            </div>
            <p className="text-sm text-slate-600 leading-relaxed mb-4 line-clamp-3">&ldquo;{t.text}&rdquo;</p>
            <div>
              <p className="text-sm font-bold text-slate-800">{t.name}</p>
              <p className="text-xs text-slate-400">— {t.location}</p>
            </div>
          </div>
        ))}
      </div>

      <div className="text-center mt-6">
        <a href="/testimonials" className="inline-flex items-center gap-1.5 text-sm font-semibold text-orange-500 hover:text-orange-600 transition-colors">
          All Testimonials <ArrowRight size={14} />
        </a>
      </div>
    </div>
  );
}

/* ═══════════════════════════════════════════════════
   SEO CONTENT SECTION
   ═══════════════════════════════════════════════════ */
function SeoSection() {
  return (
    <div className="mt-10 space-y-8">
      <div className="bg-white rounded-xl border border-slate-200 p-6">
        <h3 className="text-lg font-extrabold text-slate-900 mb-3">Sports, hobbies &amp; leisure</h3>
        <p className="text-sm text-slate-600 leading-relaxed mb-3">
          The sports industry is a developing community. The notion of being fit is constantly growing in trend. Why not to make use of the demand for the accessories related to exercise to make more profit?
        </p>
        <p className="text-sm text-slate-600 leading-relaxed">
          Are you running an e-shop or let alone an online wholesale store that offers products related to some sport activity? Offer your customers even more types of products at a better price: describe the categories in your inventory. Most of us consider regular stocks of sports and leisure accessories. This way you can buy quality goods for a fraction of their full list value, and then sell them to a wider consumer base to increase revenue.
        </p>
      </div>
      <div className="bg-white rounded-xl border border-slate-200 p-6">
        <h3 className="text-lg font-extrabold text-slate-900 mb-3">Wholesale sporting goods - variety of offers</h3>
        <p className="text-sm text-slate-600 leading-relaxed">
          For sole proprietors, all sporting goods delivered to your party by wholesalers include a variety of products. These are often very common and/or automotive commodities that can be easily traded in both wholesale and retail to any end customer.
        </p>
      </div>
    </div>
  );
}

/* ═══════════════════════════════════════════════════
   CTA BANNER
   ═══════════════════════════════════════════════════ */
function CtaBanner() {
  return (
    <div className="mt-12 bg-gradient-to-r from-slate-900 to-slate-800 rounded-2xl p-8 sm:p-12 text-center relative overflow-hidden">
      <div className="absolute inset-0 opacity-10">
        <div className="absolute top-4 left-8 text-6xl">🏷️</div>
        <div className="absolute bottom-4 right-8 text-6xl">📦</div>
      </div>
      <div className="relative z-10">
        <p className="text-xs font-bold text-orange-400 uppercase tracking-wider mb-2">Get Started!</p>
        <h2 className="text-2xl sm:text-3xl font-extrabold text-white mb-4">
          Ready to Increase Your<br />Reseller Earnings?
        </h2>
        <p className="text-sm text-slate-300 max-w-lg mx-auto mb-6 leading-relaxed">
          Here you can buy wholesale and dropship products at profit margins up to 60% to 90% and more. Start by uploading your inventory, start selling successfully — it&apos;s easy and enjoyable.
        </p>
        <a href="/register" className="inline-flex px-8 py-3 text-sm font-bold text-white bg-orange-500 hover:bg-orange-600 rounded-full transition-all shadow-lg">
          Register Now!
        </a>
      </div>
    </div>
  );
}

/* ═══════════════════════════════════════════════════
   MAIN — /deals page
   ═══════════════════════════════════════════════════ */
export default function DealsPage() {
  const [isPremium, setIsPremium] = useState(false);
  const [filters, setFilters] = useState({
    rating: null,
    categories: [],
    priceMin: "",
    priceMax: "",
    countries: [],
    dropshipping: false,
    grades: [],
    keyword: "",
  });
  const [sortBy, setSortBy] = useState("latest");
  const [searchMode, setSearchMode] = useState("any");
  const [inlineSearch, setInlineSearch] = useState("");
  const [page, setPage] = useState(1);
  const [perPage, setPerPage] = useState(9);
  const [mobileFilterOpen, setMobileFilterOpen] = useState(false);
  const [filterCollapsed, setFilterCollapsed] = useState(false);

  // Triple the products for more realistic grid
  const allProducts = [...PRODUCTS, ...PRODUCTS, ...PRODUCTS].map((p, i) => ({ ...p, id: i + 1 }));
  const visibleProducts = allProducts.filter((p) => !p.isExpired);

  return (
    <div className="min-h-screen bg-slate-50">
      {/* Main content area */}
      <div className="px-4 sm:px-6 py-6">
        {/* Breadcrumb */}
        <Breadcrumb items={[
          { label: "WholesaleUp", href: "/" },
          { label: "Deals" },
        ]} />

        {/* Page Header — full width */}
        <div className="mb-6">
          <div className="flex items-start justify-between gap-4">
            <div className="flex-1 min-w-0">
              <h1 className="text-2xl font-extrabold text-slate-900">Deals</h1>
              <p className="text-sm text-slate-500 mt-1">
                Discover in used and wholesale suppliers that fit your business needs. Find top-quality accessories, made-to-measure goods for brand and own-brand products at competitive wholesale prices. We connect you with reliable UK-based sources to optimise your inventory and{" "}
                <a href="#" className="text-orange-500 hover:text-orange-600 font-medium">Show More</a>
              </p>
            </div>
            {/* Demo toggle */}
            <button
              onClick={() => setIsPremium(!isPremium)}
              className={`hidden sm:flex items-center gap-1.5 px-4 py-2 rounded-lg text-xs font-semibold transition-all shrink-0 ${
                isPremium ? "bg-amber-100 text-amber-700" : "bg-slate-100 text-slate-600"
              }`}
            >
              {isPremium ? <Unlock size={12} /> : <Lock size={12} />}
              {isPremium ? "Premium" : "Free"}
            </button>
          </div>
        </div>

        {/* Layout: Filter Sidebar + Content */}
        <div className="flex gap-6 items-start">
          {/* Collapsible Filter Panel */}
          <div className="hidden lg:block relative shrink-0">
            <div className={`transition-all duration-300 ease-in-out overflow-hidden ${filterCollapsed ? "w-0" : "w-72"}`}>
              <div className="w-72">
                <FilterSidebar
                  filters={filters}
                  setFilters={setFilters}
                  isOpen={mobileFilterOpen}
                  onClose={() => setMobileFilterOpen(false)}
                />
              </div>
            </div>
            {/* Filter toggle button — narrow vertical bar, aligned with sidebar toggle */}
            <button
              onClick={() => setFilterCollapsed(!filterCollapsed)}
              className={`absolute top-14 w-3 h-16 bg-orange-600 hover:bg-orange-500 rounded-r flex items-center justify-center transition-all z-10 shadow-md ${
                filterCollapsed ? "left-0" : "-right-3"
              }`}
              title={filterCollapsed ? "Show filters" : "Hide filters"}
            >
              <ChevronDown size={10} className={`text-white transition-transform ${filterCollapsed ? "-rotate-90" : "rotate-90"}`} />
            </button>
          </div>

          {/* Content Area */}
          <div className="flex-1 min-w-0">
            {/* Toolbar */}
            <SearchToolbar
              title="Deals"
              totalCount={4691}
              filters={filters}
              setFilters={setFilters}
              sortBy={sortBy}
              setSortBy={setSortBy}
              searchMode={searchMode}
              setSearchMode={setSearchMode}
              inlineSearch={inlineSearch}
              setInlineSearch={setInlineSearch}
              onToggleMobileFilter={() => setMobileFilterOpen(!mobileFilterOpen)}
            />

            {/* Hot Offers Section 1 */}
            <div className="mt-6">
              <HotOffersSection
                title="Hot Wholesale & Dropship Offers"
                subtitle="Products"
                products={visibleProducts.slice(0, 6)}
                isPremium={isPremium}
              />
            </div>

            {/* Hot Offers Section 2 */}
            <HotOffersSection
              title="Hot Wholesale & Dropship Offers"
              subtitle="Products"
              products={visibleProducts.slice(6, 12)}
              isPremium={isPremium}
            />

            {/* Hot Offers Section 3 */}
            <HotOffersSection
              title="Hot Wholesale & Dropship Offers"
              subtitle="Products"
              products={visibleProducts.slice(12, 18)}
              isPremium={isPremium}
            />

            {/* Pagination */}
            <Pagination
              total={897}
              page={page}
              setPage={setPage}
              perPage={perPage}
              setPerPage={setPerPage}
            />

            {/* SEO Content */}
            <SeoSection />

            {/* Related Searches */}
            <RelatedSearches />

            {/* Trust Section */}
            <TrustSection />

            {/* CTA Banner */}
            <CtaBanner />
          </div>
        </div>
      </div>

      {/* Mobile filter overlay */}
      {mobileFilterOpen && (
        <div className="fixed inset-0 bg-black/40 z-40 lg:hidden" onClick={() => setMobileFilterOpen(false)} />
      )}
    </div>
  );
}

/* ── Named exports for homepage and other pages ── */
export { DetailedDealCard, PRODUCTS, FLAGS };
