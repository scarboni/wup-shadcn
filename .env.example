# ─────────────────────────────────────────────────────────────
# WholesaleUp — Environment Variables
# Copy to .env.local and fill in all required values
# ─────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ─────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/wholesaleup?schema=public"

# ── Auth (REQUIRED) ─────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── OAuth Providers (optional — comment out to disable) ─────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_ID=
APPLE_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ── reCAPTCHA v3 (REQUIRED) ─────────────────────────────────
# Get keys from: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── Email Service (REQUIRED) ────────────────────────────────
# Supported: "resend" | "sendgrid" | "ses"
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM=noreply@wholesaleup.com
EMAIL_REPLY_TO=support@wholesaleup.com

# ── Rate Limiting (optional — falls back to in-memory) ──────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Monitoring (optional) ───────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_ANALYTICS_ID=
